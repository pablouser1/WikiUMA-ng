{
    "name": "pablouser1/wikiuma-ng",
    "description": "Valoraciones a profesores de la UMA",
    "license": "AGPL-3.0-or-later",
    "type": "project",
    "version": "1.3.0",
    "authors": [
        {
            "name": "Pablo Ferreiro",
            "email": "contact@pabloferreiro.es"
        }
    ],
    "require": {
        "ext-iconv": "*",
        "adhocore/cli": "^1.9.4",
        "chillerlan/php-cache": "^5.1.0",
        "illuminate/database": "^13.7.0",
        "illuminate/events": "^13.7.0",
        "illuminate/pagination": "^13.7.0",
        "laminas/laminas-diactoros": "^3.8.0",
        "laminas/laminas-httphandlerrunner": "^2.13.0",
        "league/commonmark": "^2.8.2",
        "league/plates": "^3.6.0",
        "league/route": "^6.2.0",
        "monolog/monolog": "^3.10.0",
        "npm-asset/bulma": "^1.0.4",
        "pablouser1/umawrapper": "^1.1.3",
        "phpmailer/phpmailer": "^7.0",
        "ramsey/uuid": "^4.9.2",
        "yassinedoghri/php-icons": "^1.3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "friendsofphp/php-cs-fixer": "^3.95.1"
    },
    "suggest": {
        "ext-apcu": "APCu cache support",
        "ext-igbinary": "Serializer",
        "ext-redis": "Redis cache support"
    },
    "repositories": [
        {
